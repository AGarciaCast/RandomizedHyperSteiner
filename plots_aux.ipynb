    "from pathlib import Path\n",
    "import matplotlib.patches as patches\n",
    "\n",
    "\n",
    "try:\n",
    "    from phcpy.phcpy2c3 import py2c_set_seed\n",
    "    ALLOW_PRECISE = True\n",
    "    \n",
    "except ModuleNotFoundError:\n",
    "    ALLOW_PRECISE = False\n",
