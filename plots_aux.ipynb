    "                   s=TERMINAL_SIZE, edgecolors=\"#F7F7F5\",\n",
    "                   linewidths=MARKER_EDGEWIDTH, zorder=10)\n",
    "\n",
    "    # --- Axis styling ---\n",
    "    if space == \"Half\":\n",
